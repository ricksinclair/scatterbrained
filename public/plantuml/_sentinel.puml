  arrow { LineColor #0A0B09; }
}
sequenceDiagram {
  lifeline { LineColor #0A0B08; }
  participant, actor, boundary, control, entity, database, collections, queue { BackgroundColor #0A0B07; LineColor #0A0B09; FontColor #0A0B01; }
  group, box { BackgroundColor #0A0B06; LineColor #0A0B09; FontColor #0A0B02; }
  separator { BackgroundColor #0A0B07; FontColor #0A0B02; LineColor #0A0B08; }
}
activityDiagram {
