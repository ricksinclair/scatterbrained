  RoundCorner 12
  Margin 8
  Padding 6
}
element { BackgroundColor #0A0B07; }
arrow { LineColor #0A0B02; FontColor #0A0B02; }
note { BackgroundColor #0A0B06; LineColor #0A0B04; FontColor #0A0B01; }
