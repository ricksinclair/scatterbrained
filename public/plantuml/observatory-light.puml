' observatory-light.puml — PlantUML theme matching Scatterbrained Studio's "observatory" theme (light).
' GENERATED from public/lib/themes.js — do not edit; run `npm run gen:puml`.
' Usage: !include <path>/observatory-light.puml at the top of any diagram.
' Element stereotypes <<Insight>> <<Project>> <<Idea>> … color as Scatterbrained graph node types.

skinparam defaultFontName Inter
skinparam defaultMonospacedFontName JetBrains Mono
skinparam shadowing false
skinparam backgroundColor #ffffff
skinparam roundCorner 12
skinparam ArrowColor #5A6483
skinparam ArrowFontColor #5A6483
skinparam ActivityDiamondBackgroundColor #EEF1FB
skinparam SequenceGroupBodyBackgroundColor transparent
skinparam SequenceLifeLineBorderColor #D6D9E6

<style>
root {
  FontName "Inter"
  FontSize 13
  FontColor #1B2233
  LineColor #7882B4
  LineThickness 1
  RoundCorner 12
  Margin 8
  Padding 6
}
element { BackgroundColor #EEF1FB; }
arrow { LineColor #5A6483; FontColor #5A6483; }
note { BackgroundColor #E5E3F6; LineColor #5A4FC0; FontColor #1B2233; }
title { FontColor #1B2233; FontSize 16; }
header, footer { FontColor #656F94; }
caption { FontColor #5A6483; }
mindmapDiagram {
  node { BackgroundColor #EEF1FB; LineColor #7882B4; FontColor #1B2233; RoundCorner 14; }
  rootNode { BackgroundColor #5A4FC0; FontColor #FFFFFF; LineColor #5A4FC0; FontStyle bold; RoundCorner 14; }
  arrow { LineColor #7882B4; }
}
wbsDiagram {
  node { BackgroundColor #EEF1FB; LineColor #7882B4; FontColor #1B2233; RoundCorner 14; }
  rootNode { BackgroundColor #5A4FC0; FontColor #FFFFFF; LineColor #5A4FC0; FontStyle bold; RoundCorner 14; }
  arrow { LineColor #7882B4; }
}
sequenceDiagram {
  lifeline { LineColor #D6D9E6; }
  participant, actor, boundary, control, entity, database, collections, queue { BackgroundColor #EEF1FB; LineColor #7882B4; FontColor #1B2233; }
  group, box { BackgroundColor #E5E3F6; LineColor #7882B4; FontColor #5A6483; }
  separator { BackgroundColor #EEF1FB; FontColor #5A6483; LineColor #D6D9E6; }
}
activityDiagram {
  activity, diamond { BackgroundColor #EEF1FB; LineColor #7882B4; FontColor #1B2233; }
  partition { BackgroundColor transparent; LineColor #D6D9E6; FontColor #5A6483; }
}
.Insight { BackgroundColor #E8E7F9; LineColor #7F77DD; FontColor #1B2233; }
.Rule { BackgroundColor #D6EEE6; LineColor #1D9E75; FontColor #1B2233; }
.Idea { BackgroundColor #FCEED8; LineColor #EF9F27; FontColor #1B2233; }
.Source { BackgroundColor #EAE9E8; LineColor #888780; FontColor #1B2233; }
.Project { BackgroundColor #DBEAF9; LineColor #378ADD; FontColor #1B2233; }
.Goal { BackgroundColor #F7E0E8; LineColor #D4537E; FontColor #1B2233; }
.Person { BackgroundColor #F7E0E8; LineColor #D4537E; FontColor #1B2233; }
.Organization { BackgroundColor #EAE9E8; LineColor #888780; FontColor #1B2233; }
.Resource { BackgroundColor #D6EEE6; LineColor #1D9E75; FontColor #1B2233; }
.Skill { BackgroundColor #FCEED8; LineColor #EF9F27; FontColor #1B2233; }
.SyncState { BackgroundColor #E3E3E7; LineColor #646478; FontColor #1B2233; }
.warn { BackgroundColor #E5E3F6; LineColor #B5651D; FontColor #B5651D; }
.ok { BackgroundColor #E5E3F6; LineColor #1D8A66; FontColor #1D8A66; }
</style>

