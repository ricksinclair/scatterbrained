' nebula-dark.puml — PlantUML theme matching Scatterbrained Studio's "nebula" theme (dark).
' GENERATED from scatterbrained-studio/public/lib/themes.js — do not edit; run `npm run gen:puml`.
' Usage: !include <path>/nebula-dark.puml at the top of any diagram.
' Element stereotypes <<Insight>> <<Project>> <<Idea>> … color as Scatterbrained graph node types.

skinparam defaultFontName Inter
skinparam defaultMonospacedFontName JetBrains Mono
skinparam shadowing false
skinparam backgroundColor #190a26
skinparam roundCorner 12
skinparam ArrowColor #B89BD6
skinparam ArrowFontColor #B89BD6
skinparam ActivityDiamondBackgroundColor #241133
skinparam SequenceGroupBodyBackgroundColor transparent
skinparam SequenceLifeLineBorderColor #472C59

<style>
root {
  FontName "Inter"
  FontSize 13
  FontColor #F0E2FF
  LineColor #AA78C8
  LineThickness 1
  RoundCorner 12
  Margin 8
  Padding 6
}
element { BackgroundColor #241133; }
arrow { LineColor #B89BD6; FontColor #B89BD6; }
note { BackgroundColor #48225D; LineColor #C77DFF; FontColor #F0E2FF; }
title { FontColor #F0E2FF; FontSize 16; }
header, footer { FontColor #8D72B0; }
caption { FontColor #B89BD6; }
mindmapDiagram {
  node { BackgroundColor #241133; LineColor #AA78C8; FontColor #F0E2FF; RoundCorner 14; }
  rootNode { BackgroundColor #C77DFF; FontColor #190A26; LineColor #C77DFF; FontStyle bold; RoundCorner 14; }
  arrow { LineColor #AA78C8; }
}
wbsDiagram {
  node { BackgroundColor #241133; LineColor #AA78C8; FontColor #F0E2FF; RoundCorner 14; }
  rootNode { BackgroundColor #C77DFF; FontColor #190A26; LineColor #C77DFF; FontStyle bold; RoundCorner 14; }
  arrow { LineColor #AA78C8; }
}
sequenceDiagram {
  lifeline { LineColor #472C59; }
  participant, actor, boundary, control, entity, database, collections, queue { BackgroundColor #241133; LineColor #AA78C8; FontColor #F0E2FF; }
  group, box { BackgroundColor #48225D; LineColor #AA78C8; FontColor #B89BD6; }
  separator { BackgroundColor #241133; FontColor #B89BD6; LineColor #472C59; }
}
activityDiagram {
  activity, diamond { BackgroundColor #241133; LineColor #AA78C8; FontColor #F0E2FF; }
  partition { BackgroundColor transparent; LineColor #472C59; FontColor #B89BD6; }
}
.Insight { BackgroundColor #2B1E47; LineColor #7F77DD; FontColor #F0E2FF; }
.Rule { BackgroundColor #1A2534; LineColor #1D9E75; FontColor #F0E2FF; }
.Idea { BackgroundColor #402526; LineColor #EF9F27; FontColor #F0E2FF; }
.Source { BackgroundColor #2D2136; LineColor #888780; FontColor #F0E2FF; }
.Project { BackgroundColor #1E2147; LineColor #378ADD; FontColor #F0E2FF; }
.Goal { BackgroundColor #3B1736; LineColor #D4537E; FontColor #F0E2FF; }
.Person { BackgroundColor #3B1736; LineColor #D4537E; FontColor #F0E2FF; }
.Organization { BackgroundColor #2D2136; LineColor #888780; FontColor #F0E2FF; }
.Resource { BackgroundColor #1A2534; LineColor #1D9E75; FontColor #F0E2FF; }
.Skill { BackgroundColor #402526; LineColor #EF9F27; FontColor #F0E2FF; }
.SyncState { BackgroundColor #271A35; LineColor #646478; FontColor #F0E2FF; }
.warn { BackgroundColor #48225D; LineColor #FF9E6D; FontColor #FF9E6D; }
.ok { BackgroundColor #48225D; LineColor #6FE0C0; FontColor #6FE0C0; }
</style>

