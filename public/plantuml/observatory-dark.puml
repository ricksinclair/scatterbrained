' observatory-dark.puml — PlantUML theme matching Scatterbrained Studio's "observatory" theme (dark).
' GENERATED from public/lib/themes.js — do not edit; run `npm run gen:puml`.
' Usage: !include <path>/observatory-dark.puml at the top of any diagram.
' Element stereotypes <<Insight>> <<Project>> <<Idea>> … color as Scatterbrained graph node types.

skinparam defaultFontName Inter
skinparam defaultMonospacedFontName JetBrains Mono
skinparam shadowing false
skinparam backgroundColor #0b0f22
skinparam roundCorner 12
skinparam ArrowColor #8B93C8
skinparam ArrowFontColor #8B93C8
skinparam ActivityDiamondBackgroundColor #11152A
skinparam SequenceGroupBodyBackgroundColor transparent
skinparam SequenceLifeLineBorderColor #32385A

<style>
root {
  FontName "Inter"
  FontSize 13
  FontColor #DFE4FF
  LineColor #7882BE
  LineThickness 1
  RoundCorner 12
  Margin 8
  Padding 6
}
element { BackgroundColor #11152A; }
arrow { LineColor #8B93C8; FontColor #8B93C8; }
note { BackgroundColor #242C5E; LineColor #8C97FF; FontColor #DFE4FF; }
title { FontColor #DFE4FF; FontSize 16; }
header, footer { FontColor #7179A4; }
caption { FontColor #8B93C8; }
mindmapDiagram {
  node { BackgroundColor #11152A; LineColor #7882BE; FontColor #DFE4FF; RoundCorner 14; }
  rootNode { BackgroundColor #8C97FF; FontColor #0B0F22; LineColor #8C97FF; FontStyle bold; RoundCorner 14; }
  arrow { LineColor #7882BE; }
}
wbsDiagram {
  node { BackgroundColor #11152A; LineColor #7882BE; FontColor #DFE4FF; RoundCorner 14; }
  rootNode { BackgroundColor #8C97FF; FontColor #0B0F22; LineColor #8C97FF; FontStyle bold; RoundCorner 14; }
  arrow { LineColor #7882BE; }
}
sequenceDiagram {
  lifeline { LineColor #32385A; }
  participant, actor, boundary, control, entity, database, collections, queue { BackgroundColor #11152A; LineColor #7882BE; FontColor #DFE4FF; }
  group, box { BackgroundColor #242C5E; LineColor #7882BE; FontColor #8B93C8; }
  separator { BackgroundColor #11152A; FontColor #8B93C8; LineColor #32385A; }
}
activityDiagram {
  activity, diamond { BackgroundColor #11152A; LineColor #7882BE; FontColor #DFE4FF; }
  partition { BackgroundColor transparent; LineColor #32385A; FontColor #8B93C8; }
}
.Insight { BackgroundColor #202244; LineColor #7F77DD; FontColor #DFE4FF; }
.Rule { BackgroundColor #0E2931; LineColor #1D9E75; FontColor #DFE4FF; }
.Idea { BackgroundColor #342923; LineColor #EF9F27; FontColor #DFE4FF; }
.Source { BackgroundColor #222533; LineColor #888780; FontColor #DFE4FF; }
.Project { BackgroundColor #132544; LineColor #378ADD; FontColor #DFE4FF; }
.Goal { BackgroundColor #2F1B33; LineColor #D4537E; FontColor #DFE4FF; }
.Person { BackgroundColor #2F1B33; LineColor #D4537E; FontColor #DFE4FF; }
.Organization { BackgroundColor #222533; LineColor #888780; FontColor #DFE4FF; }
.Resource { BackgroundColor #0E2931; LineColor #1D9E75; FontColor #DFE4FF; }
.Skill { BackgroundColor #342923; LineColor #EF9F27; FontColor #DFE4FF; }
.SyncState { BackgroundColor #1B1E31; LineColor #646478; FontColor #DFE4FF; }
.warn { BackgroundColor #242C5E; LineColor #F0A35A; FontColor #F0A35A; }
.ok { BackgroundColor #242C5E; LineColor #7FE0B8; FontColor #7FE0B8; }
</style>

