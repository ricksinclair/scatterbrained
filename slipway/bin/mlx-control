#!/usr/bin/env bash
# Open the MLX server control panel (zero-dependency stdlib web app).
set -euo pipefail
PANEL="$HOME/Projects/mlx-control/server.py"
PORT=8765

# Already running? Just open it.
if curl -sf "http://127.0.0.1:${PORT}/api/status" >/dev/null 2>&1; then
  open "http://127.0.0.1:${PORT}"
  exit 0
fi

nohup python3 "$PANEL" >"$HOME/.claude-code-router/mlx-control.log" 2>&1 &
for i in $(seq 1 20); do
  curl -sf "http://127.0.0.1:${PORT}/api/status" >/dev/null 2>&1 && break
  sleep 0.3
done
open "http://127.0.0.1:${PORT}"
echo "Control panel running at http://127.0.0.1:${PORT}"
