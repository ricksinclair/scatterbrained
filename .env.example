# "what changed?" probing. Create an integration at notion.so/my-integrations,
# share the KB database with it, then fill these in (this file is .env, gitignored).
# NOTION_TOKEN=ntn_xxx
# NOTION_KB_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
