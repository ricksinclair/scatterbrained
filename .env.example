# NEO4J_PASSWORD must match your running instance. The default below matches the
# bundled docker-compose.yml ("neo4j/engram-local"). If you point Engram at a
# graph you stood up separately, set this to THAT instance's password — otherwise
# scripts fail with "unauthorized due to authentication failure".
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=engram-local

# --- Optional: token-based Notion change detection (scripts/notion-index.js) ---
# Leave unset to use the MCP path. Set both to enable deterministic, headless
# "what changed?" probing. Create an integration at notion.so/my-integrations,
# share the KB database with it, then fill these in (this file is .env, gitignored).
# NOTION_TOKEN=ntn_xxx
# NOTION_KB_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional: stand up the operations workspace (scripts/new-project.js,
#     scripts/setup-notion.js). NOTION_PARENT_PAGE_ID is a Notion page you've
#     shared with the integration; the workspace is created under it. ---
# NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
