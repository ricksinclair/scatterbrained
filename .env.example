NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=scatterbrained-local

# --- Optional: token-based Notion change detection (scripts/notion-index.js) ---
# Leave unset to use the MCP connector path. Set NOTION_TOKEN to enable
# deterministic, headless "what changed?" probing via /v1/search — it returns
# everything shared with the integration, so connecting it ONCE at your one-root
# parent page covers every project subpage (no KB database needed). Create an
# integration at notion.so/my-integrations, add it on your one-root page, then
# fill this in (this file is .env, gitignored).
# NOTION_TOKEN=ntn_xxx
# NOTION_KB_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # optional — only for legacy single-database mode

# --- Optional: stand up the operations workspace (scripts/new-project.js,
#     scripts/setup-notion.js). NOTION_PARENT_PAGE_ID is a Notion page you've
#     shared with the integration; the workspace is created under it. ---
# NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
