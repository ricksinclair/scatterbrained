{
  "name": "scatterbrained",
  "version": "0.1.0-alpha.3",
  "description": "A second brain you can see — a local-first Studio (no-build visual app) over your Neo4j knowledge graph, plus an agent-maintained, bi-temporal graph toolkit; Notion and local files as capture lanes.",
  "keywords": [
    "knowledge-graph",
    "neo4j",
    "second-brain",
    "knowledge-management",
    "data-visualization",
    "graph-visualization",
    "local-first",
    "observatory",
    "notion",
    "cypher"
  ],
  "homepage": "https://github.com/ricksinclair/scatterbrained",
  "repository": {
    "type": "git",
    "url": "https://github.com/ricksinclair/scatterbrained.git"
  },
  "license": "MIT",
  "author": "Ulric Todman (https://ulrictodman.com)",
  "type": "module",
  "bin": {
    "scatterbrained": "bin/scatterbrained.js"
  },
  "files": [
    "bin/",
    "server.js",
    "public/",
    "lib/",
    "scripts/",
    "studio-scripts/",
    "queries/",
    "examples/",
    "skills/",
    "docker-compose.yml",
    ".env.example",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node studio-scripts/start.mjs",
    "studio": "node server.js",
    "test": "node --test test/cli/*.test.js",
    "test:studio": "vitest run",
    "code-graph": "node bin/code-graph.mjs",
    "context": "node scripts/build-context.js",
    "add": "node scripts/add-node.js",
    "insight": "node scripts/write-insight.js",
    "export": "node scripts/export-graph.js",
    "import": "node scripts/import-graph.js",
    "index": "node scripts/notion-index.js",
    "doc-index": "node scripts/document-index.js",
    "lint:graph": "node scripts/lint-graph.js",
    "protected-fact:check": "node scripts/protected-fact-check.js",
    "release:sanity": "node scripts/release-sanity.js",
    "digest": "node scripts/digest.js",
    "search": "node scripts/search.js",
    "embed": "node scripts/embed.js",
    "supersede": "node scripts/supersede.js",
    "review:supersession": "node scripts/review-supersession.js",
    "review:docs": "node scripts/review-doc-staleness.js",
    "review:decisions": "node scripts/review-undocumented-decisions.js",
    "writeback": "node scripts/write-back-decisions.js",
    "check:notion": "node scripts/check-notion.js",
    "setup:notion": "node scripts/setup-notion.js",
    "new:project": "node scripts/new-project.js",
    "resume": "node scripts/resume.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "neo4j-driver": "^5.28.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
